# Discord
# Bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token

# Your Discord user ID (right-click yourself → Copy User ID with Developer Mode on)
DISCORD_ID=your_discord_user_id

# Webhook URL (only needed when MODE=WEBHOOK)
DISCORD_WEBHOOK=https://discord.com/api/webhooks/...

# Send mode: DM (default) or WEBHOOK
MODE=DM

# Notion
# Integration token from https://www.notion.so/my-integrations
NOTION_TOKEN=secret_...

# OpenAI
# API key from https://platform.openai.com/api-keys
CHATGPT_KEY=sk-...

# Model to use for AI calls (default: gpt-4o-mini)
CHATGPT_MODEL=gpt-4o-mini

# NewsAPI
# Free key from https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key

# Timezone for cron scheduling (default: UTC)
# Use IANA zone names, e.g. Asia/Taipei, America/New_York
TIME_ZONE=UTC
