generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Vocabulary {
  id         Int    @id @default(autoincrement())
  word       String
  pageId     String @unique
  stageIndex Int    @default(0)
}

model SeenNews {
  id         Int      @id @default(autoincrement())
  url        String   @unique
  title      String
  category   String
  seenAt     DateTime @default(now())
}

model NotionCache {
  id              Int      @id @default(autoincrement())
  pageId          String   @unique
  word            String
  partOfSpeech    String
  definition      String
  sentences       String
  transformations String
  synonyms        String
  antonyms        String
  commonPhrases   String
  createdAt       DateTime @default(now())
}
